# =============================================================================
# Application Configuration
# =============================================================================
APP_NAME=CattleSaaS
APP_ENV=development
APP_DEBUG=true
APP_PORT=8000

# =============================================================================
# Database Configuration (SQL Server)
# =============================================================================
DATABASE_URL=mssql+pymssql://sa:YourStrong!Passw0rd@localhost:1433/cattlesaas
SQLSERVER_HOST=localhost
SQLSERVER_PORT=1433
SQLSERVER_DATABASE=cattlesaas
SQLSERVER_USERNAME=sa
SQLSERVER_PASSWORD=YourStrong!Passw0rd
SQLSERVER_DRIVER=ODBC Driver 18 for SQL Server
SQLSERVER_TRUST_CERT=yes

# Connection String Alternative
SQL_SERVER_CONNECTION_STRING=mssql+pyodbc://sa:YourStrong!Passw0rd@localhost:1433/cattlesaas?driver=ODBC+Driver+18+for+SQL+Server&TrustServerCertificate=yes

# =============================================================================
# Databricks Configuration
# =============================================================================
DATABRICKS_HOST=https://your-workspace.cloud.databricks.com
DATABRICKS_TOKEN=your-databricks-access-token
DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/your-warehouse-id
DATABRICKS_CLUSTER_ID=your-cluster-id
DATABRICKS_WORKSPACE_ID=your-workspace-id

# Databricks SQL Warehouse
DATABRICKS_SQL_WAREHOUSE_ID=your-sql-warehouse-id

# =============================================================================
# Azure Storage Configuration
# =============================================================================
AZURE_STORAGE_ACCOUNT_NAME=your-storage-account
AZURE_STORAGE_ACCOUNT_KEY=your-storage-key
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=your-account;AccountKey=your-key;EndpointSuffix=core.windows.net

# Azure Blob Containers
AZURE_BRONZE_CONTAINER=bronze
AZURE_SILVER_CONTAINER=silver
AZURE_GOLD_CONTAINER=gold
AZURE_RAW_CONTAINER=raw-data

# =============================================================================
# Multi-Tenancy Configuration
# =============================================================================
TENANT_ID=test-tenant-001
DEFAULT_TENANT_ID=default

# =============================================================================
# SQL Server Configuration (Transactional Database)
# =============================================================================
SQL_SERVER_HOST=localhost
SQL_SERVER_PORT=1433
SQL_SERVER_DATABASE=cattlesaas
SQL_SERVER_USER=sa
SQL_SERVER_PASSWORD=YourStrong!Passw0rd
SQL_SERVER_DRIVER=ODBC Driver 18 for SQL Server

# Connection String
SQL_SERVER_CONNECTION_STRING=mssql+pyodbc://${SQL_SERVER_USER}:${SQL_SERVER_PASSWORD}@${SQL_SERVER_HOST}:${SQL_SERVER_PORT}/${SQL_SERVER_DATABASE}?driver=ODBC+Driver+18+for+SQL+Server&TrustServerCertificate=yes

# =============================================================================
# MinIO Configuration (Local S3-compatible storage for testing)
# =============================================================================
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
MINIO_BUCKET_BRONZE=bronze
MINIO_BUCKET_SILVER=silver
MINIO_BUCKET_GOLD=gold

# =============================================================================
# Delta Lake Configuration
# =============================================================================
DELTA_LAKE_PATH=/mnt/delta
DELTA_BRONZE_PATH=${DELTA_LAKE_PATH}/bronze
DELTA_SILVER_PATH=${DELTA_LAKE_PATH}/silver
DELTA_GOLD_PATH=${DELTA_LAKE_PATH}/gold

# =============================================================================
# API Authentication
# =============================================================================
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# =============================================================================
# External Services
# =============================================================================
# SendGrid for email notifications
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=noreply@cattlesaas.com

# Twilio for SMS alerts
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# =============================================================================
# Monitoring & Logging
# =============================================================================
LOG_LEVEL=INFO
LOG_FORMAT=json

# Application Insights (Azure)
APPINSIGHTS_INSTRUMENTATION_KEY=your-instrumentation-key
APPINSIGHTS_CONNECTION_STRING=InstrumentationKey=your-key;IngestionEndpoint=https://your-region.in.applicationinsights.azure.com/

# =============================================================================
# Redis Configuration (Caching & Session Management)
# =============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}/${REDIS_DB}

# =============================================================================
# CORS Configuration
# =============================================================================
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=*
CORS_ALLOW_HEADERS=*

# =============================================================================
# Rate Limiting
# =============================================================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60

# =============================================================================
# Feature Flags
# =============================================================================
FEATURE_REAL_TIME_MONITORING=true
FEATURE_PREDICTIVE_ANALYTICS=false
FEATURE_MULTI_TENANT=true

# =============================================================================
# Testing Configuration
# =============================================================================
TEST_DATABASE_URL=sqlite:///./test.db
TEST_MODE=false
