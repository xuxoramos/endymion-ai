# Bronze Layer Environment Configuration
#
# Copy to .env and customize as needed
# Source with: source databricks/bronze/.env

# ========================================
# MinIO Configuration
# ========================================
export MINIO_ENDPOINT="http://localhost:9000"
export MINIO_ACCESS_KEY="minioadmin"
export MINIO_SECRET_KEY="minioadmin"

# MinIO bucket names
export BRONZE_BUCKET="bronze"
export SILVER_BUCKET="silver"
export GOLD_BUCKET="gold"

# ========================================
# SQL Server Configuration
# ========================================
export SQL_SERVER="localhost"
export SQL_DATABASE="CattleSaaS"
export SQL_USER="sa"
export SQL_PASSWORD="YourStrong!Passw0rd"

# ========================================
# Bronze Ingestion Configuration
# ========================================

# Maximum events to process per batch
export BRONZE_BATCH_SIZE="1000"

# Poll interval in seconds (continuous mode)
export BRONZE_POLL_INTERVAL="10"

# Maximum retries for failed operations
export BRONZE_MAX_RETRIES="3"

# ========================================
# Spark Configuration
# ========================================

# Number of shuffle partitions (adjust based on data volume)
export SPARK_SHUFFLE_PARTITIONS="4"

# Default parallelism (should match CPU cores)
export SPARK_DEFAULT_PARALLELISM="4"

# Log level: DEBUG, INFO, WARN, ERROR
export SPARK_LOG_LEVEL="WARN"

# ========================================
# Delta Lake Configuration
# ========================================

# Enable change data feed
export DELTA_ENABLE_CHANGE_DATA_FEED="true"

# Enable auto optimize
export DELTA_AUTO_OPTIMIZE="true"

# Enable auto compaction
export DELTA_AUTO_COMPACT="true"

# ========================================
# Monitoring & Logging
# ========================================

# Enable verbose logging
export BRONZE_VERBOSE="false"

# Log file path
export BRONZE_LOG_FILE="/tmp/bronze_ingestion.log"

# ========================================
# Development Mode
# ========================================

# Skip MinIO health checks (faster startup)
export SKIP_HEALTH_CHECKS="false"

# Use in-memory Spark (faster for small datasets)
export USE_MEMORY_SPARK="false"
